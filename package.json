{
  "name": "gemini-tts-demo",
  "version": "1.0.0",
  "description": "Gemini TTS demo with cost tracking",
  "main": "dist/server.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && mkdir -p dist/public && cp -R src/public/* dist/public/",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.50.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "wav": "^1.0.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/wav": "^1.0.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
